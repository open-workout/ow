apiVersion: v1
kind: Secret
metadata:
  name: ow-secrets
  namespace: ow
type: Opaque
data:
  # All values are base64-encoded. Run: printf '%s' 'value' | base64
  POSTGRES_DSN_USER: PLACEHOLDER
  POSTGRES_DSN_EXERCISE: PLACEHOLDER
  POSTGRES_DSN_WORKOUT: PLACEHOLDER
  REDIS_DSN: PLACEHOLDER
  AUTH0_DOMAIN: PLACEHOLDER
  AUTH0_AUDIENCE: PLACEHOLDER
